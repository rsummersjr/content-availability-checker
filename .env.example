# YouTube Data API v3 Key
# Get your API key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Apple Music API Key (JWT Token)
# Requires Apple Developer Program membership
# Get your token from: https://developer.apple.com/documentation/applemusicapi
APPLE_MUSIC_API_KEY=your_apple_music_api_key_here

# Email Notifications (Optional)
# Configure these if you want to send real email notifications
# Leave blank to use simulation mode (emails logged to console)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@musictrackfinder.com

# Database (Optional - defaults to SQLite)
# DATABASE_URL=sqlite:///monitors.db
